<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatGraph"
    app:startDestination="@id/chatFragment">
    <fragment
        android:id="@+id/chatFragment"
        tools:layout="@layout/fragment_coin"
        android:name="com.coinlive.uikit.framents.ChatFragment"
        android:label="ChatFragment" >
        <action
            android:id="@+id/action_chatFragment_to_textFragment"
            app:destination="@id/textFragment" >
            <argument
                android:name="title"
                app:argType="string" />
            <argument
                android:name="description"
                app:argType="string" />
        </action>
        <action
            android:id="@+id/action_chattingFragment_to_translatorSettingFragment"
            app:destination="@id/translatorSettingFragment" />

    </fragment>
    <fragment
        android:id="@+id/textFragment"
        tools:layout="@layout/fragment_text"
        android:name="com.coinlive.uikit.framents.TextFragment"
        android:label="TextFragment" >
        <action
            android:id="@+id/action_textFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>
    <fragment
        tools:layout="@layout/fragment_translator_setting"
        android:id="@+id/translatorSettingFragment"
        android:name="com.coinlive.uikit.framents.TranslatorSettingFragment"
        android:label="TranslatorSettingFragment" >
        <action
            android:id="@+id/action_translatorSettingFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>
</navigation>