<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="chat"
            type="com.coinlive.chat.firebase.model.Chat" />

        <variable
            name="locale"
            type="String" />

        <variable
            name="price"
            type="String" />

        <variable
            name="isRoundMessage"
            type="Boolean" />

        <variable
            name="isSameDate"
            type="Boolean" />

    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <com.coinlive.uikit.views.OtherTextMessageView
            android:id="@+id/base"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chat="@{chat}"
            app:isEnableTranslator="@{false}"
            app:isRoundMessage="@{isRoundMessage}"
            app:isSameDate="@{isSameDate}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:originMsg="@{locale.equals(`ko`)? chat.koMessage : chat.enMessage}" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_asset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="56dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="19dp"
            android:background="@drawable/asset_chatting_background"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="8dp"
            app:layout_constraintStart_toStartOf="@id/base"
            app:layout_constraintTop_toBottomOf="@id/base">

            <ImageView
                android:id="@+id/iv_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:loadIcon="@{chat.asset.iconUrl}"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_symbol"
                style="@style/subtitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@{chat.symbol}"
                android:textColor="@color/normal_text"
                app:layout_constraintBottom_toBottomOf="@id/iv_icon"
                app:layout_constraintStart_toEndOf="@id/iv_icon"
                app:layout_constraintTop_toTopOf="@id/iv_icon" />

            <TextView
                android:id="@+id/tv_price"
                style="@style/subtitle3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{price}"
                android:textColor="@color/normal_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_icon" />

            <ImageView
                android:id="@+id/iv_exchange"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                app:layout_constraintBottom_toBottomOf="@id/tv_price"
                app:layout_constraintStart_toEndOf="@id/tv_price"
                app:layout_constraintTop_toTopOf="@id/tv_price"
                app:loadExchangeImage="@{chat.asset.exchange}"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_description"
                style="@style/asset_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/asset_description"
                android:textColor="@color/asset_chat_description"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_price"
                tools:ignore="TextContrastCheck" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.coinlive.uikit.views.EmojiView
            android:id="@+id/emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:emojiMap="@{chat.emoji}"
            app:layout_constraintBottom_toTopOf="@id/v_bottom"
            app:layout_constraintStart_toStartOf="@id/base"
            app:layout_constraintTop_toBottomOf="@id/cl_asset" />


        <View
            android:id="@+id/v_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/normal_message_bottom_margin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_asset" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>