<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="chat"
            type="com.coinlive.chat.firebase.model.Chat" />

        <variable
            name="isRoundMessage"
            type="Boolean" />

        <variable
            name="locale"
            type="String" />

        <variable
            name="isSameDate"
            type="Boolean" />

        <variable
            name="enableTranslator"
            type="Boolean" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_date"
            style="@style/body2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:textColor="@color/normal_text"
            android:visibility="@{isSameDate ? View.GONE : View.VISIBLE}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:setDate="@{chat.insertTime}" />

        <ImageButton
            android:id="@+id/ibtn_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:background="@android:color/transparent"
            android:visibility="@{isRoundMessage ? View.INVISIBLE : View.VISIBLE}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_date"
            app:loadProfile="@{chat.profileUrl}"
            tools:ignore="ContentDescription,SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/tv_nickName"
            style="@style/caption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@{chat.userNickname}"
            android:textColor="@color/normal_text"
            android:visibility="@{isRoundMessage ? View.GONE : View.VISIBLE}"
            app:layout_constraintStart_toEndOf="@id/ibtn_profile"
            app:layout_constraintTop_toBottomOf="@id/tv_date" />

        <TextView
            android:id="@+id/tv_appName"
            style="@style/caption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@{chat.appName.toUpperCase()}"
            android:textColor="@color/grey_030"
            android:visibility="@{isRoundMessage ? View.GONE : View.VISIBLE}"
            app:layout_constraintBottom_toBottomOf="@id/tv_nickName"
            app:layout_constraintStart_toEndOf="@id/tv_nickName"
            app:layout_constraintTop_toTopOf="@id/tv_nickName" />

        <TextView
            android:id="@+id/tv_lable"
            style="@style/ama_lable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/shape_ama_label"
            android:paddingHorizontal="6dp"
            android:text="AMA"
            android:visibility="@{isRoundMessage ? View.GONE : (chat.label == null ? View.GONE : View.VISIBLE)}"
            app:layout_constraintBottom_toBottomOf="@id/tv_appName"
            app:layout_constraintStart_toEndOf="@id/tv_appName"
            app:layout_constraintTop_toTopOf="@id/tv_appName" />

        <TextView
            android:id="@+id/tv_msg"
            style="@style/body2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:autoLink="web"
            android:background="@{isRoundMessage ? @drawable/shape_round_other_msg_background : @drawable/shape_other_msg_background}"
            android:gravity="start"
            android:linksClickable="false"
            android:maxWidth="246dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="@{locale.equals(`ko`)? chat.koMessage : chat.enMessage}"
            android:textColor="@color/normal_text"
            android:textColorLink="@color/sub_blue_500"
            app:layout_constraintStart_toEndOf="@id/ibtn_profile"
            app:layout_constraintTop_toBottomOf="@id/tv_nickName" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_trans"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ibtn_profile"
            app:layout_constraintTop_toBottomOf="@id/tv_nickName"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_trans_msg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@{isRoundMessage ? @drawable/shape_round_other_msg_background : @drawable/shape_other_msg_background}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_origin_msg"
                    style="@style/body2"
                    android:text="@{locale.equals(`ko`)? chat.koMessage : chat.enMessage}"
                    android:textColor="@color/normal_text"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <View
                    android:id="@+id/v_divider"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_origin_msg"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@color/normal_text"
                    android:layout_width="0dp"
                    android:layout_height="1dp"/>

                <TextView
                    android:id="@+id/tv_trans_msg"
                    style="@style/body2"
                    android:layout_marginTop="8dp"
                    android:text="dfassdafsa"
                    android:textColor="@color/normal_text"
                    app:layout_constraintTop_toBottomOf="@id/v_divider"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:visibility="@{isRoundMessage ? View.GONE : View.VISIBLE}"
                android:id="@+id/iv_copy"
                android:layout_marginTop="4dp"
                android:src="@drawable/img_translated_by_google"
                app:layout_constraintTop_toBottomOf="@id/cl_trans_msg"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:ignore="ContentDescription" />
        </androidx.constraintlayout.widget.ConstraintLayout>




        <TextView
            android:id="@+id/tv_time"
            style="@style/caption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="19dp"
            android:textColor="@color/chat_msg_time_text"
            android:visibility="@{isRoundMessage ? View.GONE : View.VISIBLE}"
            app:layout_constraintBottom_toBottomOf="@id/tv_msg"
            app:layout_constraintStart_toEndOf="@id/tv_msg"
            app:setTime="@{chat.insertTime}" />

        <ImageButton
            android:id="@+id/ibtn_translator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:background="@android:color/transparent"
            android:src="@drawable/icon_translator_16"
            android:visibility="@{enableTranslator ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toTopOf="@id/tv_time"
            app:layout_constraintStart_toEndOf="@id/tv_msg"
            tools:ignore="ContentDescription" />

        <View
            android:id="@+id/v_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/normal_message_bottom_margin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_msg" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>