<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="chat"
            type="com.coinlive.chat.firebase.model.Chat" />

        <variable
            name="locale"
            type="String" />

        <variable
            name="isRoundMessage"
            type="Boolean" />

        <variable
            name="isSameDate"
            type="Boolean" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_root"
        android:layout_marginEnd="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp">


        <TextView
            android:id="@+id/tv_date"
            style="@style/body2"
            android:visibility="@{isSameDate ? View.GONE : View.VISIBLE}"
            android:textColor="@color/normal_text"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:setDate ="@{chat.insertTime}"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>

        <ImageView
            android:id="@+id/iv_one"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="60dp"
            android:adjustViewBounds ="true"
            android:cropToPadding="false"
            android:maxWidth="241dp"
            android:visibility="@{chat.images.size() > 1 ? View.GONE : View.VISIBLE}"
            app:layout_constraintTop_toBottomOf="@id/tv_date"
            app:layout_constraintEnd_toEndOf="parent"
            app:loadImageMessage="@{chat.images[0]}"
            tools:ignore="ContentDescription" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_list"
            android:visibility="@{chat.images.size() > 1 ? View.VISIBLE : View.GONE}"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:maxHeight="241dp"
            android:maxWidth="241dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:padding="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_date"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/v_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_time"
            style="@style/caption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:textColor="@color/chat_msg_time_text"
            app:layout_constraintBottom_toBottomOf="@id/rv_list"
            app:layout_constraintEnd_toStartOf="@id/rv_list"
            app:setTime="@{chat.insertTime}" />

        <View
            android:id="@+id/v_bottom"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_list" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>