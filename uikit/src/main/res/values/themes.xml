<resources>

    <style name="PopupMenu" parent="@android:style/Widget.Holo.ListView.DropDown">
        <item name="android:background">@drawable/shape_menu_chat_background</item>
        <item name="android:divider">#FF0000</item>
        <item name="android:dividerHeight">2dp</item>
    </style>

    <style name="circleProgress">
        <item name="colorAccent">@color/primary</item>
    </style>

    <style name="header1">
        <item name="android:textSize">28dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="header2">
        <item name="android:textSize">24dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="header3">
        <item name="android:textSize">20dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="subtitle1">
        <item name="android:textSize">18dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="subtitle2">
        <item name="android:textSize">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="subtitle2.5">
        <item name="android:textSize">15dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="subtitle3">
        <item name="android:textSize">14dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="subtitle4">
        <item name="android:textSize">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="body1">
        <item name="android:textSize">16dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="body2">
        <item name="android:textSize">14dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="caption1">
        <item name="android:textSize">12dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="caption1.5">
        <item name="android:textSize">11dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="caption2">
        <item name="android:textSize">10dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="asset_description">
        <item name="android:textSize">12dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="appbar_live_count">
        <item name="android:textSize">14dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="ama_lable">
        <item name="android:textColor">@color/ama_label</item>
        <item name="android:textSize">9dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="new_msg_nickname">
        <item name="android:textColor">@color/grey_050</item>
        <item name="android:textSize">12dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="@style/Theme.Design.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomShapeAppearanceBottomSheetDialog</item>
    </style>

    <style name="CustomShapeAppearanceBottomSheetDialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <style name="translator_item">
        <item name="android:textColor">@color/normal_text</item>
        <item name="android:textSize">18dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="dialog" parent="ThemeOverlay.AppCompat.Dialog">
        <item name="background">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="ama_live">
        <item name="android:textSize">14dp</item>
        <item name="android:textStyle">normal</item>
    </style>

</resources>